<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="950.0" styleClass="main-window" stylesheets="@style.css" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://xml.com/fxml/1" fx:controller="com.example.sms.HelloController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" styleClass="header-bar">
            <children>
                <Label styleClass="header-title" text="Student Management System" />
            </children>
            <padding>
                <Insets left="24.0" />
            </padding>
        </HBox>

        <HBox VBox.vgrow="ALWAYS" spacing="24.0">
            <children>
                <VBox prefWidth="320.0" styleClass="card-panel" spacing="24.0">
                    <children>
                        <VBox spacing="16.0">
                            <children>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Name:" />
                                        <TextField fx:id="txtName" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Course:" />
                                        <TextField fx:id="txtCourse" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label styleClass="form-label" text="Year Level:" />
                                        <ChoiceBox fx:id="cbYear" maxWidth="Infinity" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Button maxWidth="Infinity" onAction="#addStudent" prefHeight="38.0" styleClass="btn-add" text="Add" />
                                <Button maxWidth="Infinity" onAction="#updateStudent" prefHeight="38.0" styleClass="btn-update" text="Update" />
                                <Button maxWidth="Infinity" onAction="#deleteStudent" prefHeight="38.0" styleClass="btn-delete" text="Delete" />
                                <Button maxWidth="Infinity" onAction="#clearFields" prefHeight="38.0" styleClass="btn-clear" text="Clear" />
                            </children>
                            <padding>
                                <Insets top="8.0" />
                            </padding>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                </VBox>

                <VBox styleClass="card-panel" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <TableView fx:id="table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                                <TableColumn fx:id="colName" prefWidth="220.0" text="Name" />
                                <TableColumn fx:id="colCourse" prefWidth="200.0" text="Course" />
                                <TableColumn fx:id="colYear" prefWidth="150.0" text="Year Level" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
        </HBox>
    </children>
</VBox>